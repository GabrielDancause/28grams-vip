---
import BaseHead from '../layouts/BaseHead.astro';

const tools = [
  { emoji: "⚖️", name: "Recipe Yield Scaler", desc: "Scale any recipe up or down. Enter the original yield, your target, and get every ingredient recalculated.", soon: false, slug: "/recipe-scaler" },
  { emoji: "🍞", name: "Baker's Percentage Calculator", desc: "Convert any bread recipe to baker's percentages — or go the other way. The pro baker's best friend.", soon: false, slug: "/bakers-percentage" },
  { emoji: "🌡️", name: "Metric ↔ Imperial Converter", desc: "Cups to grams, Fahrenheit to Celsius, ounces to milliliters. Every kitchen conversion in one place.", soon: false, slug: "/cooking-converter" },
  { emoji: "🍞", name: "Sourdough Calculator", desc: "Sourdough ratios. Flour weight, hydration, starter %. Water, starter, salt. Timing schedule.", soon: false, slug: "/sourdough-calculator" },
  { emoji: "🌡️", name: "Sous Vide Calculator", desc: "Sous vide time/temp for any protein. Beef, pork, chicken, fish, eggs.", soon: false, slug: "/sous-vide" },
  { emoji: "☕", name: "Coffee Brew Ratio Calculator", desc: "Coffee-to-water ratios. Pour-over, French press, espresso, cold brew.", soon: false, slug: "/coffee-ratio" },
  { emoji: "🍕", name: "Pizza Dough Calculator", desc: "Calculate exact flour, water, yeast, salt, and oil for any number of pizza dough balls. Neapolitan, New York, and more.", soon: false, slug: "/pizza-dough" },
  { emoji: "🥩", name: "Smoking Calculator", desc: "Time and temperature for smoking any meat. Brisket, ribs, pork shoulder, chicken — with rest time and stall estimates.", soon: false, slug: "/smoking-calculator" },
  { emoji: "🍺", name: "ABV Calculator", desc: "Calculate alcohol by volume from original and final gravity readings. Supports Brix and SG.", soon: false, slug: "/abv-calculator" },
  { emoji: "🍞", name: "Bread Hydration Calculator", desc: "Calculate true hydration percentage for any bread recipe. Accounts for preferments, enriched doughs, and whole grains.", soon: false, slug: "/bread-hydration" },
  { emoji: "🫙", name: "Fermentation Timer", desc: "Fermentation schedules. Bread, yogurt, kombucha, kimchi. Temp-adjusted.", soon: false, slug: "/fermentation-timer" },
  { emoji: "📋", name: "Nutrition Label Creator", desc: "FDA-style nutrition labels. Serving size, nutrients. Printable. DV %.", soon: false, slug: "/nutrition-label" },
  { emoji: "🌶️", name: "Spice Substitution Guide", desc: "Substitutes for 100+ spices. Ratio adjustments. Best alternatives.", soon: false, slug: "/spice-substitution" },
  { emoji: "🥡", name: "Meal Prep Calculator", desc: "Weekly meal prep portions. Shopping list. Macros per meal.", soon: false, slug: "/meal-prep" },
  { emoji: "🥚", name: "Egg Substitute Calculator", desc: "Baking egg substitutes. Flax, chia, applesauce, banana, aquafaba.", soon: false, slug: "/egg-substitute" },
  { emoji: "📚", name: "Sourdough Starter: Complete Guide", desc: "How to create and maintain a sourdough starter. Day-by-day timeline, feeding schedule, troubleshooting.", soon: false, slug: "/guide-sourdough" },
  { emoji: "📚", name: "Bread Baking for Beginners", desc: "Start baking bread at home. Equipment, flour types, kneading, proofing, baking. First recipe.", soon: false, slug: "/guide-bread-baking" },
  { emoji: "📚", name: "Home Fermentation Guide", desc: "Start fermenting at home. Sauerkraut, kimchi, kombucha, yogurt. Equipment, safety, troubleshooting.", soon: false, slug: "/guide-fermentation" },
  { emoji: "🧈", name: "Butter & Sugar Substitution", desc: "Out of butter? Need less sugar? Find the right substitute and the exact amount to use.", soon: true },
  { emoji: "⏱️", name: "Cooking Time Adjuster", desc: "Changing pan size or altitude? Recalculate baking time and temperature automatically.", soon: true },
  { emoji: "🥘", name: "Serving Cost Calculator", desc: "How much does each plate really cost? Add ingredients, quantities, and prices — get cost per serving.", soon: true },
];
---
<html lang="en">
<head>
  <BaseHead
    title="28 Grams — Recipe Scaling, Baker's Percentages & Culinary Conversion Tools"
    description="Free culinary calculators: recipe yield scaler, baker's percentage calculator, metric to imperial converter, substitution guides, and serving cost calculator. No signup."
    ogTitle="28 Grams — Precision Cooking Starts Here"
    ogDescription="Recipe scaling, baker's percentages, unit conversions, and culinary calculators. Free, fast, no signup."
  />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0a060a; color: #e0d0d8; }
    .hero { text-align: center; padding: 100px 24px 80px; background: linear-gradient(180deg, #1a0a14 0%, #0a060a 100%); position: relative; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(circle at 50% 40%, rgba(122,27,61,0.1) 0%, transparent 60%); }
    .hero-content { position: relative; z-index: 1; }
    .hero h1 { font-size: 3rem; font-weight: 900; letter-spacing: -1.5px; margin-bottom: 12px; background: linear-gradient(135deg, #fff 0%, #C2185B 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero p { color: #666; font-size: 1.05rem; max-width: 480px; margin: 0 auto; }
    .grid { max-width: 900px; margin: 0 auto; padding: 0 24px 100px; display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; }
    .card { background: #120c10; border: 2px solid #2a1820; border-radius: 16px; padding: 28px 24px; position: relative; text-decoration: none; color: inherit; display: block; transition: border-color 0.2s, transform 0.2s; }
    .card:hover { border-color: #C2185B; transform: translateY(-2px); }
    .card .emoji { font-size: 2rem; margin-bottom: 12px; display: block; }
    .card h2 { font-size: 1.1rem; font-weight: 700; color: #fff; margin-bottom: 6px; }
    .card p { font-size: 0.85rem; color: #888; line-height: 1.6; }
    .badge { position: absolute; top: 14px; right: 14px; background: #2a1820; color: #C2185B; font-size: 0.65rem; font-weight: 700; padding: 3px 10px; border-radius: 20px; }
    .footer { text-align: center; padding: 40px 24px; font-size: 0.78rem; color: #333; border-top: 1px solid #1a0e15; }
    .footer a { color: #C2185B; text-decoration: none; }
    @media (max-width: 600px) { .hero h1 { font-size: 2.2rem; } .hero { padding: 70px 20px 50px; } .grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>
<div class="hero">
  <div class="hero-content">
    <h1>28 Grams 🍳</h1>
    <p>Precision cooking tools. Scale recipes, nail baker's percentages, convert anything.</p>
  </div>
</div>
<div class="grid">
  {tools.map(t => (
    <a class="card" href={t.slug || '#'} style={t.soon ? 'pointer-events:none' : ''}>
      {t.soon ? <span class="badge">COMING SOON</span> : <span class="badge" style="background:#1a2a1a;color:#4ade80;">LIVE</span>}
      <span class="emoji">{t.emoji}</span>
      <h2>{t.name}</h2>
      <p>{t.desc}</p>
    </a>
  ))}
</div>
<div class="footer">© 2025 <a href="https://28grams.vip">28grams.vip</a> · A <a href="https://gab.ae">GAB Ventures</a> property</div>
</body>
</html>
